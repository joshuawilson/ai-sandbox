# Copy to vm-host.env (same directory) and adjust, or run: ./host/configure-vm-host.sh
# vm-host.env is gitignored — per-machine settings.

# Libvirt / Hyper-V / UTM VM name (disk file uses this name too on Linux/Windows).
VM_NAME=ai-sandbox

# Virtual disk size for a new install (gigabytes).
VM_DISK_GB=80

# RAM in mebibytes (1024 MiB = 1 GiB). Examples: 8192 ≈ 8 GiB, 16384 ≈ 16 GiB, 32768 ≈ 32 GiB.
VM_MEMORY_MIB=32768

VM_VCPUS=8

# virt-install --cpu: host-model (default), host-passthrough, host, …
VM_CPU_MODE=host-model

# Fedora release for netinstall URL and --os-variant (Linux) / ISO selection (Mac/Windows).
FEDORA_VER=43

# Optional: override netinstall tree (Linux virt-install --location). If unset, Everything/x86_64/os/ is used.
# LOCATION_URL=https://download.fedoraproject.org/pub/fedora/linux/releases/43/Everything/x86_64/os/

# Linux libvirt: qcow2 directory (qemu must read here — default is the standard pool).
VM_DIR=/var/lib/libvirt/images

# Linux libvirt: NAT network from virsh net-list (usually default).
VM_LIBVIRT_NETWORK=default

# Mac: Fedora Server netinstall aarch64 (for Tart). Windows: Fedora Workstation live ISO x86_64.
VM_ISO_URL=https://download.fedoraproject.org/pub/fedora/linux/releases/43/Server/aarch64/iso/Fedora-Server-netinst-aarch64-43-1.6.iso

# Windows Hyper-V: virtual switch (must exist). Default Switch is common on Windows 10/11.
VM_HYPERV_SWITCH='Default Switch'
