# Red Hat internal Claude Code (Vertex) — copy to claude-vertex.env on the HOST repo checkout,
# or let setup-claude.sh write workspace/.ai-sandbox-private/claude-vertex.env when secrets/ is read-only from the VM.
# Those files are gitignored. install-inside-vm.sh copies either into ~/.config/ai-sandbox/claude-vertex.env.
# Replace YOUR_GCP_PROJECT_ID with the project ID from your team spreadsheet.

export CLAUDE_CODE_USE_VERTEX=1
export CLOUD_ML_REGION=us-east5
export ANTHROPIC_VERTEX_PROJECT_ID='your-gcp-project-id'
