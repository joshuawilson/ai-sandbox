# Copy to the Fedora guest as /etc/ai-sandbox/cifs.env (and adjust).
# Use when the host shares the whole ai-sandbox directory over SMB (see create-vm-windows.ps1 -CreateSmbShare).
#
# USE_CIFS=1
# CIFS_URL=//192.168.1.10/ai-sandbox
# CIFS_CREDENTIALS=/etc/ai-sandbox/smbcredentials
#
# Create /etc/ai-sandbox/smbcredentials (chmod 600) with:
#   username=windows_user
#   password=secret
#   domain=WORKGROUP
