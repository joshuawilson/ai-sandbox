CONTAINER_IMAGE="ai-dev"

CPU_LIMIT=6
MEMORY_LIMIT=16g
PID_LIMIT=512

SECRETS_DIR="/mnt/host-secrets"
# Dev containers mount $HOME/.ssh (not SECRETS_DIR/ssh): rootless Podman often cannot statfs virtiofs paths.
# install-inside-vm.sh copies secrets/ssh/id_ed25519* into ~/.ssh on the guest disk.
# Per-project repos: host-backed workspace/<name>/ (virtiofs) → container /workspace
WORKSPACE_ROOT="$HOME/ai-sandbox/workspace"

# SELinux + virtiofs: start-container auto sets --security-opt label=disable when the workspace
# mount is virtiofs. Force: AI_SANDBOX_PODMAN_LABEL_DISABLE=1  |  strict :z/:Z: AI_SANDBOX_PODMAN_LABEL_DISABLE=0
